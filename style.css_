body {
  background: linear-gradient(to right, #141e30, #243b55);
  font-family: Arial, sans-serif;
  text-align: center;
  margin-top: 100px;
  color: white;
}

h1 {
  font-size: 48px;
}

p {
  font-size: 20px;
  opacity: 0.8;
}

button {
  margin-top: 20px;
  padding: 12px 25px;
  font-size: 16px;
  background-color: #00c6ff;
  border: none;
  border-radius: 8px;
  color: white;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  background-color: #0072ff;
  transform: scale(1.05);
}
